# Copy this file to `.env` and adjust as needed.
# `.env` is gitignored; this example file is not.
#
# These defaults are pre-configured for the demo bomb in ./demo-bomb, so a
# fresh clone can run end-to-end with:
#
#     cp .env.example .env
#     cp demo-bomb/bomb ./bomb
#     ./run.sh demo-bomb/solution.txt
#
# To target a course-issued bomb instead, see the "Switching to your own
# bomb" section in README.md.

# What the shim makes gethostname() return inside the bomb. Despite the
# name, this is effectively the *hostname* the bomb's initialize_bomb()
# will compare against. For a course-issued bomb that value happens to
# equal the userid baked into .data; for the demo bomb the two differ on
# purpose (hostname=demohost, userid=demouser).
BOMB_USERID=demohost

# Port the bomb dials and the fake grader listens on. Must match the value
# compiled into the bomb's init_driver. Course bomb: 27054 (default if
# unset). Demo bomb: 12345. Comment this line out when running a course bomb.
BOMB_SHIM_PORT=12345

# Optional: where shim/fake_server.py appends per-request submission logs.
# Defaults to shim/submissions.log if unset.
# BOMB_SHIM_LOG=shim/submissions.log
