# Copy this file to `.env` and fill in the value for your bomb.
# `.env` is gitignored; this example file is not.
#
# BOMB_USERID must match the `userid` string baked into your bomb binary.
# The hostcheck inside initialize_bomb() uses strcasecmp, so case does not
# matter, but the value must otherwise be exact.
#
# You can recover it from the binary with:
#
#     objdump -s -j .data bomb | less     # look for the `userid` symbol
#     objdump -t bomb | grep '\buserid\b' # gives the address
#     strings bomb | head                  # often enough on its own
#
BOMB_USERID=your_userid_here
